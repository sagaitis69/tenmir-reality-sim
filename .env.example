# Google AI Studio / Gemini API (OpenAI-compatible surface for Gemma 4)
# Create a key: https://aistudio.google.com/apikey
OPENAI_API_KEY=

# Default OpenAI-compatible base for Gemma on Google
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Model id from Google AI Studio / changelog (adjust if your account lists a different id)
LLM_MODEL=gemma-4-31b-it

# Optional: local vLLM / Ollama OpenAI shim
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# LLM_MODEL=gemma4
