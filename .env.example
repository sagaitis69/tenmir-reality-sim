# --- Gemma 4 (Google AI Studio / Gemini developer API) ---
# Key from Google (not OpenAI): https://aistudio.google.com/apikey
LLM_API_KEY=

# Google hosts Gemma behind a URL path that matches the industry "OpenAI-compatible" wire format.
# You still use the official Google key above — the name LLM_API_KEY avoids confusion.
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Gemma 4 model id (check AI Studio / docs for the exact id your project can call)
LLM_MODEL=gemma-4-31b-it

# Optional: self-hosted Gemma 4 (vLLM / Ollama) speaking the same HTTP shape
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_MODEL=gemma4

# Deprecated aliases (same values as LLM_* if you already had these set)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
